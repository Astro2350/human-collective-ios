# Keep the real file outside the repo at:
# ~/.human_collective_instagram.env

# Required for Instagram publishing.
INSTAGRAM_ACCOUNT_ID=your_instagram_business_or_creator_account_id
INSTAGRAM_ACCESS_TOKEN=your_long_lived_instagram_access_token

# Optional.
INSTAGRAM_GRAPH_API_VERSION=v25.0
POST_TIME_ZONE=America/Chicago
INSTAGRAM_CONTAINER_POLL_SECONDS=3
INSTAGRAM_CONTAINER_TIMEOUT_SECONDS=60

# Useful while testing.
DRY_RUN=1
